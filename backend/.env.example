DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/walasmulla_alumni"
# For Supabase: DATABASE_URL uses the pooled connection (port 6543, ?pgbouncer=true),
# DIRECT_URL uses the direct/session connection (port 5432) — required for migrations.
DIRECT_URL="postgresql://postgres:yourpassword@localhost:5432/walasmulla_alumni"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

UPLOAD_DIR="uploads"
STORAGE_DRIVER="local"
# STORAGE_DRIVER selects the pluggable storage backend (backend/src/lib/storage).
# Only "local" (disk, served from /uploads) is implemented today.

# Trial mode (backend/src/middleware/trial.ts): after TRIAL_START_DATE + TRIAL_LENGTH_DAYS,
# every /api/* route except /api/health returns 403. Leave unset locally to use the code's
# built-in default (also 2026-07-22 / 90 days). To extend, raise TRIAL_LENGTH_DAYS and
# redeploy — no code change needed. See PROJECT_STATUS.md "Trial Mode" section.
TRIAL_START_DATE="2026-07-22"
TRIAL_LENGTH_DAYS=90
